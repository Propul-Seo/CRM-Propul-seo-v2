# ============================================================================
# Serveur MCP Propul'SEO CRM — variables d'environnement
# ----------------------------------------------------------------------------
# 1. Copier ce fichier en `.env`  (déjà ignoré par git)
# 2. Renseigner SUPABASE_SERVICE_ROLE_KEY (secret)
# 3. Laisser MCP_DRY_RUN=true pour tester sans risque, puis passer à false.
# ============================================================================

# --- Connexion Supabase (projet ERP) ---
# URL du projet (NON secret — visible dans le navigateur)
SUPABASE_URL=https://tbuqctfgjjxnevmsvucl.supabase.co

# Clé serveur SECRÈTE (accès total à la base, ignore les RLS).
# Le projet ERP a désactivé les clés "legacy" -> utiliser la NOUVELLE clé secrète :
#   Dashboard > Project Settings > API Keys > "Secret keys" > Reveal  (format sb_secret_...)
# (À défaut, une clé service_role JWT "eyJ..." marche SI les clés legacy sont réactivées.)
# NE JAMAIS commiter, ne jamais coller dans un message, ne pas exposer côté navigateur.
SUPABASE_SERVICE_ROLE_KEY=

# Schéma PostgREST (laisser "public")
SUPABASE_SCHEMA=public

# --- Sécurité / comportement ---
# true  = AUCUNE écriture réelle : insert/update/delete renvoient seulement l'aperçu (par défaut).
# false = écritures réelles exécutées.
MCP_DRY_RUN=true

# Timeout des requêtes HTTP (secondes)
MCP_HTTP_TIMEOUT=30

# Nombre de tentatives supplémentaires sur erreur réseau / 5xx
MCP_MAX_RETRIES=2
