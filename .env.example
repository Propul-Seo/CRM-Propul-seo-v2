# ============================================================================
# Propulseo CRM — Environment variables template
# ============================================================================
# Copy this file to .env (gitignored) and fill in the values.
# All VITE_* variables are exposed to the browser. Never put secrets there.
# ============================================================================

# --- Supabase (required for app to start) ---
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Propul'Space portal (added Phase 1) ---
# URL of the public client portal (sub-domain dedicated to Propul'Space)
VITE_PUBLIC_PORTAL_URL=https://espace.propulseo-site.com

# Sentry error tracking (frontend + backend) — to be filled when account created
VITE_SENTRY_DSN=

# ============================================================================
# Edge Functions secrets (server-side only, never VITE_*)
# Set these in Supabase Dashboard → Edge Functions → Secrets
# DO NOT commit values to this file.
# ============================================================================

# --- Existing CRM integrations ---
# RESEND_API_KEY=          # Transactional emails (existing)
# PAPPERS_API_KEY=         # SIRET enrichment (existing)
# GROQ_API_KEY=            # AI summaries (existing, not used yet)

# --- Propul'Space Phase 2-3 (to be filled when arriving at each phase) ---
# BREVO_API_KEY=           # Phase 2 — replaces Resend for Propul'Space emails
# CAL_COM_API_KEY=         # Phase 2 — booking widget for qualification step 7

# --- Propul'Space Phase 3 (Stripe + DocuSeal) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# DOCUSEAL_API_KEY=
# DOCUSEAL_WEBHOOK_SECRET=
